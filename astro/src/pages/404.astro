---
import BaseLayout from "../layouts/BaseLayout.astro";
import Marquee from "../components/Marquee.astro";
---

<BaseLayout title="404 — RÜTM">
  <div class="not-found">
    <h1 class="not-found__code">404</h1>
    <p class="not-found__msg">This page doesn't exist.</p>
    <a class="not-found__back" href="/">Back to RÜTM</a>
  </div>
  <Marquee text="NOT FOUND •" speed={14} />
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    padding: 40px 24px;
  }

  .not-found__code {
    font-size: clamp(100px, 20vw, 200px);
    font-weight: 800;
    line-height: 1;
    margin: 0 0 16px;
    letter-spacing: -0.03em;
  }

  .not-found__msg {
    font-size: 16px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.5;
    margin: 0 0 32px;
  }

  .not-found__back {
    border: 2px solid var(--text-color);
    color: var(--text-color);
    text-decoration: none;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 10px 28px;
    transition: opacity 0.15s;
  }

  .not-found__back:hover { opacity: 0.7; }
</style>
