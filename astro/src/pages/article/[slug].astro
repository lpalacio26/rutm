---
import { sanity } from "../../lib/sanity";
import { portableTextToHtml } from "../../lib/portableText";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { urlFor } from "../../lib/sanityImage";
import Pill from "../../components/Pill.astro";

type Translation = {
  language: string;
  title?: string;
  content?: any[];
};

type Article = {
  title: string;
  excerpt?: string;
  publishedAt?: string;
  content?: any[];
  slug: string;
  heroImage?: any;
  heroImageCredit?: string;
  translations?: Translation[];

  author?: { name: string; slug: string };
  sections?: { title: string; slug: string }[]
};

const { slug } = Astro.params;

const query = `*[_type=="article" && slug.current == $slug][0]{
  title,
  excerpt,
  publishedAt,
  "content": coalesce(content, body)[]{
    ...,
    _type == "imageBlock" => {
      ...,
      "image": image{ ..., asset-> }
    }
  },
  "slug": slug.current,
  heroImage,
  heroImageCredit,
  "translations": translations[]{
    language,
    title,
    "content": content[]{
      ...,
      _type == "imageBlock" => {
        ...,
        "image": image{ ..., asset-> }
      }
    }
  },
  "author": author->{ name, "slug": slug.current },
  "sections": sections[]->{ title, "slug": slug.current }
}`;

const article = await sanity.fetch<Article>(query, { slug });

if (!article) {
  return new Response("Not found", { status: 404 });
}

const heroSrc = article?.heroImage
  ? urlFor(article.heroImage)
      .width(2000)
      .height(1000)
      .fit("crop")
      .quality(90)
      .url()
  : null;

const bodyHtml = portableTextToHtml(article.content ?? []);

const translations = article.translations ?? [];
const translatedBodies = translations.map((t) => ({
  language: t.language,
  title: t.title ?? article.title,
  html: portableTextToHtml(t.content ?? []),
}));

const published = article.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString("en-GB", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    })
  : null;
---

<BaseLayout title={article.title} description={article.excerpt} image={heroSrc ?? undefined}>
  <div id="progress-bar" aria-hidden="true"></div>
  <article class="article">
    {/* 1) Full-bleed main image */}
    {
      heroSrc ? (
        <div class="hero">
          <img src={heroSrc} alt={article.title} loading="eager" />
        </div>
      ) : (
        <div class="hero">
          <div class="ph" aria-hidden="true" />
        </div>
      )
    }

    {/* Centered column */}
    <div class="content">

      {/* 2) Big title */}
      <h1 class="title" data-lc="en">{article.title}</h1>
      {translatedBodies.map((t) => (
        <h1 class="title" data-lc={t.language} hidden>{t.title}</h1>
      ))}

      {/* 3) Section pills */}
      {article.sections && article.sections.length > 0 ? (
        <div class="pills-row" style="justify-content: center;">
          {article.sections.map((s) => (
            <Pill href={`/section/${s.slug}`}>{s.title}</Pill>
          ))}
        </div>
      ) : null}

      {/* 3b) Language switcher */}
      <div class="lang-switcher">
        <button class="lang-btn" data-lang="en">EN</button>
        {translatedBodies.map((t) => (
          <button class="lang-btn" data-lang={t.language}>
            {t.language.toUpperCase()}
          </button>
        ))}
      </div>

      {/* 4) Author */}
      {
        article.author ? (
          <div class="meta">
            Words by{" "}
            <a href={`/author/${article.author.slug}`}>{article.author.name}</a>
          </div>
        ) : null
      }

      {/* 5) Publication date */}
      {published ? <div class="meta">{published}</div> : null}

      {/* 6) Article body */}
      <div class="prose" data-lc="en" set:html={bodyHtml}></div>
      {translatedBodies.map((t) => (
        <div class="prose" data-lc={t.language} hidden set:html={t.html}></div>
      ))}
      {/* 7) Hero image credit */}
{article.heroImageCredit ? (
  <p class="hero-credit">{article.heroImageCredit}</p>
) : null}
    </div>
  </article>
</BaseLayout>

<style>
  /* Full page wrapper */
  .article {
    padding-bottom: 80px;
  }

  /* 1) Full-bleed hero */
  .hero {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    height: clamp(280px, 60vh, 600px);
  }
  .hero img,
  .hero .ph {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Centered content column */
  .content {
    max-width: 800px;
    margin: 0 auto;
    padding: 28px 24px 80px;
    display: flex;
    flex-direction: column;
  }

  .back {
    display: inline-block;
    margin-bottom: 18px;
    text-decoration: none;
    opacity: 0.9;
  }

  .title {
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.05;
    margin: 10px 0 14px;
    text-transform: uppercase;
    text-align: center;
  }

  .meta {
    font-size: 16px;
    margin: 6px auto 6px;
    opacity: 0.9;
  }

  .meta a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .hero-credit {
  margin-top: 48px;
  font-size: 12px;
  opacity: 0.45;
  text-align: right;
  letter-spacing: 0.03em;
}

  .lang-switcher {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 10px auto 4px;
  }

  .lang-btn {
    background: none;
    border: none;
    border-right: 1px solid currentColor;
    cursor: pointer;
    font: inherit;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-color);
    padding: 3px 12px;
    opacity: 0.4;
    transition: opacity 0.15s;
  }

  .lang-btn:last-child {
    border-right: none;
  }

  .lang-btn.active {
    opacity: 1;
    font-weight: bold;
  }

  .lang-btn:hover {
    opacity: 0.75;
  }

  @media (max-width: 700px) {
    .content {
      padding: 22px 18px 60px;
    }
  }
</style>

<style is:global>
  /* ─── Body prose ─────────────────────────────────────────────────────────── */
  .prose {
    margin-top: 22px;
    font-size: 18px;
    line-height: 1.65;
    text-align: justify;
    text-justify: inter-word;
    hyphens: auto;
    /* Allow floated sidenotes to extend outside this element */
    overflow: visible;
  }

  .prose p {
    margin: 0 0 16px;
  }

  /* ─── Pull quote ─────────────────────────────────────────────────────────── */
  .pull-quote {
    margin: 40px 0;
    padding: 24px 28px;
    border: 2px solid var(--text-color);
    border-bottom: 5px solid var(--text-color);
    border-radius: 2px;
    text-align: center;
  }

  .pull-quote__text {
    font-size: clamp(20px, 3vw, 26px);
    font-weight: bold;
    line-height: 1.3;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    text-align: center;
    hyphens: none;
    word-break:normal;
    overflow-wrap:normal;
  }

  .pull-quote__attribution {
    display: block;
    margin-top: 12px;
    font-size: 14px;
    opacity: 0.7;
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ─── Image block ────────────────────────────────────────────────────────── */
.image-block {
  margin: 36px 0;
}

.image-block img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 2px;
}

.image-block--wide {
  width: min(100vw, 1100px);
  margin-left: 50%;
  transform: translateX(-50%);
}

.image-block__caption {
  display: block;
  margin-top: 8px;
  font-size: 13px;
  opacity: 0.55;
  font-style: italic;
  text-align: center;
}

  /* ─── Progress bar ───────────────────────────────────────────────────────── */
  #progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background-color: #0022ff;
    z-index: 9999;
    transition: width 0.1s linear;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     FOOTNOTES
     ─────────────────────────────────────────────────────────────────────────
     Structure (generated by portableText.ts):

       <span class="fn-anchor">
         [annotated text]
         <label for="fn-N" class="fn-ref"><sup class="fn-sup">N</sup></label>
         <input type="checkbox" id="fn-N" class="fn-toggle">
         <span class="fn-note"><span class="fn-note-num">N</span> note text</span>
       </span>

     Desktop (≥ 1280px): .fn-note floats right into the page margin,
                          vertically near where it's introduced. No toggle.
     Tablet / mobile:    .fn-note is hidden; tap the superscript to expand
                          inline below the annotated text. Pure CSS via checkbox.
  ═══════════════════════════════════════════════════════════════════════════ */

  /* Wrapper — needs to be inline so the float stays in document flow */
  .fn-anchor {
    display: inline;
  }

  /* Hide the checkbox — it's only a CSS toggle mechanism */
  .fn-toggle {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
    margin: 0;
  }

  /* Superscript marker */
  .fn-ref {
    display: inline;
    cursor: default;
    user-select: none;
  }

  .fn-sup {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--text-color);
    color: var(--bg-color);
    font-size: 10px;
    font-weight: bold;
    line-height: 1;
    vertical-align: middle;
    margin-left: 3px;
    letter-spacing: 0;
    position: relative;
    top: -2px;
  }

  /* Note number inside the sidenote */
  .fn-note-num {
    font-weight: bold;
    margin-right: 5px;
    flex-shrink: 0;
  }

  /* ─── Default (tablet + mobile): inline expandable ─────────────────────── */
  .fn-note {
    display: none; /* hidden until toggled */
    width: 100%;
    box-sizing: border-box;
    font-size: 14px;
    line-height: 1.55;
    border-left: 3px solid var(--text-color);
    padding: 10px 14px;
    margin: 10px 0 6px;
    opacity: 0.85;
    background: rgba(0, 34, 255, 0.04);
  }

  /* Mobile: label is tappable */
  .fn-ref {
    cursor: pointer;
  }

  .fn-sup {
    transition: opacity 0.1s;
  }

  /* Toggle open state */
  .fn-toggle:checked ~ .fn-note {
    display: block;
  }

  /* Subtle indicator that note is open */
  .fn-toggle:checked + .fn-note .fn-sup,
  .fn-toggle:checked ~ .fn-note ~ .fn-ref .fn-sup {
    background: rgba(0, 34, 255, 0.12);
  }

  /* ─── Desktop (≥ 1280px): sidenote in the margin ───────────────────────── */
  /*
     At 1280px viewport, the .content column is 800px centered.
     Right margin available: (1280 - 800) / 2 = 240px.
     Sidenote: width 210px + 24px gap = 234px — fits with 6px to spare.

     The float is placed with margin-right: -(width + gap) which pushes
     the sidenote box entirely outside the content column's right edge.
     Because the float starts outside the column, prose lines are unaffected
     and render at full width — no text wrapping around the note.
  */
  @media (min-width: 1280px) {
    .fn-note {
      display: block; /* always visible — no toggle needed */
      float: right;
      clear: right;
      width: 210px;
      /* Push sidenote 24px past the right edge of .content */
      margin-right: -234px;   /* -(210px width + 24px gap) */
      margin-left: 0;
      margin-top: 3px;
      margin-bottom: 8px;
      font-size: 13px;
      line-height: 1.55;
      border-left: 3px solid var(--text-color);
      padding: 6px 0 6px 12px;
      background: transparent;
      opacity: 0.75;
    }

    /* On desktop: disable the label toggle (note always visible) */
    .fn-ref {
      cursor: default;
      pointer-events: none;
    }

    .fn-sup {
      opacity: 0.8;
    }

    /* Ignore the checkbox state — note is always shown via float */
    .fn-toggle:checked ~ .fn-note {
      display: block;
      float: right;
    }
  }
</style>

<script>
  // Language switcher
  const LANG_KEY = "rutm-lang";

  function setLang(lang: string) {
    document.querySelectorAll<HTMLElement>("[data-lc]").forEach((el) => {
      el.hidden = el.dataset.lc !== lang;
    });
    document.querySelectorAll<HTMLElement>(".lang-btn").forEach((btn) => {
      btn.classList.toggle("active", btn.dataset.lang === lang);
    });
    localStorage.setItem(LANG_KEY, lang);
  }

  const langBtns = [...document.querySelectorAll<HTMLElement>(".lang-btn")];
  if (langBtns.length > 0) {
    const available = langBtns.map((b) => b.dataset.lang as string);
    const saved = localStorage.getItem(LANG_KEY) ?? "en";
    setLang(available.includes(saved) ? saved : "en");
    langBtns.forEach((btn) => {
      btn.addEventListener("click", () => setLang(btn.dataset.lang as string));
    });
  }

  const bar = document.getElementById("progress-bar");
  const article = document.querySelector(".article") as HTMLElement;

  function updateProgress() {
    if (!bar || !article) return;
    const articleTop = article.offsetTop;
    const articleHeight = article.offsetHeight;
    const scrolled = window.scrollY - articleTop;
    const percent = Math.min(Math.max((scrolled / (articleHeight - window.innerHeight)) * 100, 0), 100);
    bar.style.width = `${percent}%`;
  }

  window.addEventListener("scroll", updateProgress, { passive: true });
  updateProgress();
</script>