---
import { sanity } from "../../lib/sanity";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleGrid from "../../components/ArticleGrid.astro";
import Marquee from "../../components/Marquee.astro";

type Section = {
  title: string;
};

type Article = {
  title: string;
  slug: string;
  excerpt?: string;
  publishedAt?: string;

  // try common image field names (only one needs to exist)
  heroImage?: any;
  mainImage?: any;
  coverImage?: any;
  image?: any;

  author?: { name: string; slug: string };
  sections?: { title: string; slug: string }[];
  translations?: { language: string }[];
  language?: string;
};

const { slug } = Astro.params;

const data = await sanity.fetch<{
  section: Section;
  articles: Article[];
}>(
  `{
    "section": *[_type=="section" && slug.current == $slug][0]{
      title
    },
    "articles": *[
  _type=="article" &&
  $slug in sections[]->slug.current
] | order(publishedAt desc){
  title,
  excerpt,
  publishedAt,
  heroImage,
  mainImage,
  coverImage,
  image,
  "slug": slug.current,
  "author": author->{ name, "slug": slug.current },
  "sections": sections[]->{ title, "slug": slug.current },
  "translations": translations[]{language},
  language
}

  }`,
  { slug }
);

if (!data?.section) {
  return Astro.rewrite("/404");
}
---

<BaseLayout title={data.section.title}>
  <h1>{data.section.title}</h1>

  {data.articles.length === 0
  ? <Marquee text="Coming soon ..." speed={18} />
  : <ArticleGrid articles={data.articles} />
}
</BaseLayout>

<style>
  h1 {
    text-transform: uppercase;
    text-align: center;
    border-top: 3px solid;
    border-bottom:3px solid;
    padding: 25px 0;
  }
</style>