---
import { sanity } from "../lib/sanity";

const footer = await sanity.fetch<{
  links: { label: string; url: string }[];
  socialLinks: { name: string; url: string; order: number }[];
}>(`*[_type == "siteFooter"][0]{ links, socialLinks }`);

const sortedSocialLinks = (footer?.socialLinks ?? []).sort(
  (a, b) => a.order - b.order
);

const pathname = Astro.url.pathname;
---

{footer?.links?.length > 0 && (
  <footer class="site-footer">
    <nav aria-label="Footer">
      {footer.links.map((link) => {
        const isActive = pathname === link.url;
        return (
          <a href={link.url} class="footer__link" aria-current={isActive ? "page" : undefined}>
            {link.label}
          </a>
        );
      })}
    </nav>

    {sortedSocialLinks.length > 0 && (
      <div class="footer__social">
        {sortedSocialLinks.map((link) => (
          <a
            href={link.url}
            class="footer__link footer__link--social"
            target="_blank"
            rel="noopener noreferrer"
          >
            {link.name} ↗
          </a>
        ))}
      </div>
    )}
  </footer>
)}

<style>
  .site-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--text-color);
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
  }

  nav {
    display: flex;
    gap: 2rem;
  }

  .footer__link {
    color: var(--bg-color);
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }

  .footer__link:hover,
  .footer__link[aria-current="page"] {
    opacity: 1;
  }

  .footer__link--social {
    margin-left: 15px;
  }

  @media (max-width: 768px) {
    .site-footer {
      display: none;
    }
  }
</style>